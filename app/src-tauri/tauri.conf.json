{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Image Rotator",
  "version": "0.1.0",
  "identifier": "com.romanpurtov.imagerotator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Image Rotator",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "Graphics",
    "shortDescription": "Rotate PNG images with a draggable handle.",
    "longDescription": "Image Rotator is a tiny desktop app that lets you load a folder of PNG images, rotate each one with a draggable handle (snapping to 0/90/180/270), and export the rotated copies to any folder you choose.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
